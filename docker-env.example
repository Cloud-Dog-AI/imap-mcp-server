# imap-mcp-server — Docker Environment (PS-91)
# Copy to .env and fill in secrets before running.

# ── Server Ports ─────────────────────────────────────────────────
CLOUD_DOG__API_SERVER__HOST=0.0.0.0
CLOUD_DOG__API_SERVER__PORT=8787
CLOUD_DOG__WEB_SERVER__HOST=0.0.0.0
CLOUD_DOG__WEB_SERVER__PORT=8071
CLOUD_DOG__MCP_SERVER__HOST=0.0.0.0
CLOUD_DOG__MCP_SERVER__PORT=8788
CLOUD_DOG__A2A_SERVER__HOST=0.0.0.0
CLOUD_DOG__A2A_SERVER__PORT=8789

# ── Authentication ───────────────────────────────────────────────
# Optional static API key for deterministic Docker testing.
IMAP_API_KEY=

# ── Required Config Placeholders ─────────────────────────────────
CA_BUNDLE_PATH=/etc/ssl/certs/ca-certificates.crt

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Generic operations mailbox profile. Leave blank for local surface smoke.
IMAP_OPERATIONS_HOST=
IMAP_OPERATIONS_PORT=993
IMAP_OPERATIONS_USERNAME=
IMAP_OPERATIONS_PASSWORD=
CLOUD_DOG__PROFILES__OPERATIONS__IMAP__HOST=
CLOUD_DOG__PROFILES__OPERATIONS__IMAP__PORT=993
CLOUD_DOG__PROFILES__OPERATIONS__CREDENTIALS__USERNAME=
CLOUD_DOG__PROFILES__OPERATIONS__CREDENTIALS__PASSWORD=
CLOUD_DOG__PROFILES__OPERATIONS_CLOUD_DOG__IMAP__HOST=
CLOUD_DOG__PROFILES__OPERATIONS_CLOUD_DOG__IMAP__PORT=993
CLOUD_DOG__PROFILES__OPERATIONS_CLOUD_DOG__CREDENTIALS__USERNAME=
CLOUD_DOG__PROFILES__OPERATIONS_CLOUD_DOG__CREDENTIALS__PASSWORD=

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── TLS (optional) ──────────────────────────────────────────────
# CLOUD_DOG_TLS_CA_BUNDLE=/app/certs/ca.crt
GOOGLE_REDIRECT_URL=http://127.0.0.1:8787/auth/google/callback
